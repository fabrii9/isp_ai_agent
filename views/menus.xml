    <!-- ===================================================================
         Sub-menú: Monitoreo
    ==================================================================== -->
    <menuitem id="menu_ai_monitoring"
              name="Monitoreo"
              parent="menu_ai_agent_root"
              sequence="30"
              groups="isp_ai_agent.group_ai_operator"/>

    <menuitem id="menu_ai_logs"
              name="Logs de Interacciones"
              parent="menu_ai_monitoring"
              action="action_ai_log"
