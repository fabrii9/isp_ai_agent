<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         Menú raíz: ISP AI Agent
    ==================================================================== -->
    <menuitem id="menu_ai_agent_root"
              name="AI Agent"
              sequence="85"
              web_icon="isp_ai_agent,static/description/icon.png"
              groups="isp_ai_agent.group_ai_operator"/>

    <!-- ===================================================================
         Sub-menú: Agentes
    ==================================================================== -->
    <menuitem id="menu_ai_agent_agents"
              name="Agentes"
              parent="menu_ai_agent_root"
              sequence="10"/>

    <menuitem id="menu_ai_agent_list"
              name="Mis Agentes"
